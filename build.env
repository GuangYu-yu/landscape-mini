#!/bin/bash
# Landscape Mini - 构建配置
# ============================================================

# 基础系统: "debian" 或 "alpine"
BASE_SYSTEM="${BASE_SYSTEM-debian}"

# Landscape Router 发布版本（"latest" 或类似 "v0.12.4" 的标签）
LANDSCAPE_VERSION="${LANDSCAPE_VERSION-latest}"

# Landscape 发布的 GitHub 仓库
LANDSCAPE_REPO="${LANDSCAPE_REPO-https://github.com/ThisSeanZhang/landscape}"

# Debian 版本（trixie = Debian 13 testing，内核 6.12+ 支持 BTF/BPF）
DEBIAN_RELEASE="trixie"

# Alpine 版本（v3.21 = 内核 6.12+ 支持 BTF/BPF）
ALPINE_RELEASE="${ALPINE_RELEASE-v3.21}"

# 磁盘镜像大小（MB，最终镜像会压缩，所以设大点没关系）
IMAGE_SIZE_MB="${IMAGE_SIZE_MB-2048}"

# 是否在镜像中包含 Docker（true/false）
# Docker 会增加约 200-400MB 镜像体积
INCLUDE_DOCKER="${INCLUDE_DOCKER-false}"

# Root 密码
ROOT_PASSWORD="${ROOT_PASSWORD-landscape}"

# Web 管理凭据
LANDSCAPE_ADMIN_USER="${LANDSCAPE_ADMIN_USER-root}"
LANDSCAPE_ADMIN_PASS="${LANDSCAPE_ADMIN_PASS-root}"

# 可选的 LAN / DHCP 覆盖项（渲染到 effective-landscape_init.toml）
LANDSCAPE_LAN_SERVER_IP="${LANDSCAPE_LAN_SERVER_IP:-}"
LANDSCAPE_LAN_RANGE_START="${LANDSCAPE_LAN_RANGE_START:-}"
LANDSCAPE_LAN_RANGE_END="${LANDSCAPE_LAN_RANGE_END:-}"
LANDSCAPE_LAN_NETMASK="${LANDSCAPE_LAN_NETMASK:-}"

# 本地校验选择: none | readiness | readiness,dataplane
RUN_TEST="${RUN_TEST:-none}"

# 单次镜像源探测超时时间（秒）
SOURCE_PROBE_TIMEOUT="${SOURCE_PROBE_TIMEOUT:-5}"

# 优先使用首选源（默认为官方源）多长时间后才回退（秒）
SOURCE_FAILOVER_TIMEOUT="${SOURCE_FAILOVER_TIMEOUT:-120}"

# 时区
TIMEZONE="${TIMEZONE-Asia/Shanghai}"

# 语言环境
LOCALE="${LOCALE-C.UTF-8}"
EXTRA_LOCALES="${EXTRA_LOCALES-}"

# APT 镜像源（显式覆盖）
APT_MIRROR="${APT_MIRROR:-}"
APT_MIRROR_CANDIDATES="${APT_MIRROR_CANDIDATES:-http://deb.debian.org/debian https://mirrors.tuna.tsinghua.edu.cn/debian https://mirrors.ustc.edu.cn/debian https://mirrors.aliyun.com/debian https://repo.huaweicloud.com/debian}"

# Alpine 镜像源（显式覆盖）
ALPINE_MIRROR="${ALPINE_MIRROR:-}"
ALPINE_MIRROR_CANDIDATES="${ALPINE_MIRROR_CANDIDATES:-https://dl-cdn.alpinelinux.org/alpine https://mirrors.tuna.tsinghua.edu.cn/alpine https://mirrors.ustc.edu.cn/alpine https://mirrors.aliyun.com/alpine https://repo.huaweicloud.com/alpine}"

# Docker APT 镜像源（显式覆盖）
DOCKER_APT_MIRROR="${DOCKER_APT_MIRROR:-}"
DOCKER_APT_MIRROR_CANDIDATES="${DOCKER_APT_MIRROR_CANDIDATES:-https://download.docker.com/linux/debian https://mirrors.aliyun.com/docker-ce/linux/debian https://mirrors.huaweicloud.com/docker-ce/linux/debian}"

# Docker APT GPG 地址（显式覆盖）
DOCKER_APT_GPG_URL="${DOCKER_APT_GPG_URL:-}"
DOCKER_APT_GPG_URL_CANDIDATES="${DOCKER_APT_GPG_URL_CANDIDATES:-https://download.docker.com/linux/debian/gpg https://mirrors.aliyun.com/docker-ce/linux/debian/gpg https://mirrors.huaweicloud.com/docker-ce/linux/debian/gpg}"

# 输出格式（逗号分隔的有序列表）: img, vmdk, ova
OUTPUT_FORMATS="${OUTPUT_FORMATS-img}"

# 是否压缩输出镜像（yes/no）
COMPRESS_OUTPUT="${COMPRESS_OUTPUT-yes}"